workspace "GreenRide" "Ride Service belső felépítése Component szint" {

    model {
        greenRide = softwareSystem "GreenRide Platform" {
            rideService = container "Ride Service" "Utazások indítása, követése és lezárása." "Spring Boot" {
                rideController = component "Ride Controller" "REST végpontokat biztosít az utazási műveletekhez." "Spring REST Controller"
                startRideUseCase = component "Start Ride Use Case" "Kezeli az utazás indításának üzleti folyamatát." "Spring Service"
                endRideUseCase = component "End Ride Use Case" "Kezeli az utazás lezárásának üzleti folyamatát." "Spring Service"
                ridePolicy = component "Ride Eligibility Policy" "Ellenőrzi, hogy a felhasználó és a jármű alkalmas-e az utazás indítására." "Spring Component"
                rideStateManager = component "Ride State Manager" "Kezeli az utazás állapotait és az állapotváltásokat." "Spring Component"
                vehicleGateway = component "Vehicle Service Client" "Kapcsolatot tart a Vehicle Service felé." "REST Client"
                paymentGateway = component "Payment Service Client" "Kapcsolatot tart a Payment Service felé." "REST Client"
                notificationPublisher = component "Ride Event Publisher" "Eseményeket küld az üzenetkezelő rendszer felé." "Kafka Producer"
                rideRepository = component "Ride Repository" "Perzisztencia réteg az utazási adatok tárolásához." "Spring Data JPA"
            }

            rideDb = container "Ride DB" "Utazási adatok." "PostgreSQL" "Database"
            vehicleService = container "Vehicle Service" "Járművek állapotának kezelése." "Spring Boot"
            paymentService = container "Payment Service" "Fizetés és díjszámítás." "Spring Boot"
            messageBus = container "Message Bus" "Aszinkron eseménykezelés." "Kafka"
        }

        apiGateway = softwareSystem "API Gateway" "Kérések útválasztása."
        
        apiGateway -> rideController "Utazás indítása és lezárása" "HTTPS"

        rideController -> startRideUseCase "Indítás kérés továbbítása"
        rideController -> endRideUseCase "Lezárás kérés továbbítása"

        startRideUseCase -> ridePolicy "Jogosultság és feltételek ellenőrzése"
        startRideUseCase -> vehicleGateway "Jármű állapot lekérdezése és feloldás indítása"
        startRideUseCase -> rideStateManager "Utazás állapotának létrehozása"
        startRideUseCase -> rideRepository "Utazás mentése"
        startRideUseCase -> notificationPublisher "Utazás elindult esemény"

        endRideUseCase -> rideStateManager "Utazás lezárása"
        endRideUseCase -> paymentGateway "Díjszámítás és fizetés indítása"
        endRideUseCase -> rideRepository "Lezárt utazás mentése"
        endRideUseCase -> notificationPublisher "Utazás lezárult esemény"

        rideRepository -> rideDb "Olvas és ír" "JDBC"
        vehicleGateway -> vehicleService "Jármű állapot és vezérlés" "REST"
        paymentGateway -> paymentService "Elszámolás" "REST"
        notificationPublisher -> messageBus "Esemény publikálás" "Kafka"
    }

    views {
        component rideService "RideServiceComponents" {
            include *
            autoLayout lr
        }

        styles {
            element "Component" {
                background #85bbf0
                color #000000
            }
            element "Database" {
                shape Cylinder
                background #cccccc
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
