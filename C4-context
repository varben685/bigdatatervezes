workspace "GreenRide" "Városi mikromobilitási platform" {

    model {
        # Szereplők (Actors)
        user = person "Utas / Felhasználó" "Járműveket keres, foglal és utazik a mobilalkalmazással."
        operator = person "Flottaüzemeltető" "Figyeli a járművek állapotát, karbantartást végez."
        admin = person "Adminisztrátor" "Rendszerbeállításokat, kedvezményeket és analitikát kezel."
        # --- ÚJ SZEREPLŐ ---
        helpdesk = person "Helpdesk Operátor" "Vásárlói panaszokat és technikai problémákat kezel."

        # A rendszerünk (Software System)
        greenRide = softwareSystem "GreenRide Platform" "A központi mikromobilitási rendszer, amely kiszolgálja a klienseket és kezeli a flottát."

        # Külső rendszerek (External Systems)
        iot = softwareSystem "Járművek / IoT eszközök" "Beépített GPS és zárvezérlő egységek a rollereken/bicikliken." "External"
        maps = softwareSystem "Térkép szolgáltató" "Google Maps vagy hasonló térinformatikai szolgáltatás." "External"
        payment = softwareSystem "Fizetési szolgáltató" "Stripe vagy banki gateway a tranzakciókhoz." "External"
        auth = softwareSystem "Külső Auth szolgáltató" "Google/Apple OAuth azonosítás." "External"
        notification = softwareSystem "Push/Email szolgáltató" "Firebase vagy SendGrid értesítések küldéséhez." "External"
        ticketing = softwareSystem "Ügyfélszolgálati Jegyrendszer" "Külső rendszer (pl. Jira Service Desk) a hibajegyek követésére." "External"

        # Kapcsolatok (Relationships)
        user -> greenRide "Járművet keres és foglal" "Mobile/Web"
        # --- ÚJ KAPCSOLAT (USER -> HELPDESK) ---
        user -> helpdesk "Problémát jelez (telefonon, chat-en vagy e-mailben)"

        operator -> greenRide "Flotta állapotot kezel" "Admin Portal"
        admin -> greenRide "Rendszert konfigurál és riportokat néz" "Admin Portal"
        
        # --- ÚJ KAPCSOLATOK (HELPDESK -> RENDSZEREK) ---
        helpdesk -> greenRide "Felhasználói és jármű adatokat kér le, tranzakciókat ellenőriz" "Admin/Support Portal"
        helpdesk -> ticketing "Létrehozza és frissíti a hibajegyeket" "HTTPS/API"

        greenRide -> iot "Parancsokat küld (nyitás/zár) és adatokat fogad" "MQTT/TCP"
        greenRide -> maps "Térkép- és útvonaladatokat kér le" "HTTPS/JSON"
        greenRide -> payment "Pénzügyi tranzakciókat indít" "HTTPS/JSON"
        greenRide -> auth "Felhasználót azonosít" "OIDC/OAuth2"
        greenRide -> notification "Értesítéseket továbbít" "HTTPS/API"
        greenRide -> ticketing "Ticket (nyitás/zárás/kezelés)" "HTTPS/API"
    }

    views {
        systemContext greenRide "SystemContext" {
            include *
            autoLayout lr
        }

        styles {
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
        }
    }
}
