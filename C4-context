workspace "GreenRide" "Városi mikromobilitási platform" {

    model {
        user = person "Utas / Felhasználó" "Járműveket keres, foglal és utazik a mobilalkalmazással."
        operator = person "Flottaüzemeltető" "Figyeli a járművek állapotát és kezeli a karbantartást."
        admin = person "Adminisztrátor" "Kedvezményeket, beállításokat és riportokat kezel."
        helpdesk = person "Helpdesk operátor" "Felhasználói problémákat és hibajegyeket kezel."

        greenRide = softwareSystem "GreenRide Platform" "A központi mikromobilitási rendszer."

        iot = softwareSystem "IoT eszközök" "A járművekbe épített vezérlő és helymeghatározó egységek." "External"
        maps = softwareSystem "Térkép szolgáltató" "Térképes megjelenítés és geolokáció." "External"
        paymentGateway = softwareSystem "Fizetési szolgáltató" "Bankkártyás és online fizetések feldolgozása." "External"
        identityProvider = softwareSystem "Külső azonosító szolgáltató" "Google vagy Apple bejelentkezés." "External"
        notificationProvider = softwareSystem "Push és email szolgáltató" "Értesítések kiküldése." "External"
        ticketingSystem = softwareSystem "Jegykezelő rendszer" "Ügyfélszolgálati hibajegyek nyilvántartása." "External"

        user -> greenRide "Járművet keres, foglal és használ" "Mobile app"
        operator -> greenRide "Flottaadatokat és járműállapotot kezel" "Admin portal"
        admin -> greenRide "Rendszerbeállításokat és üzleti szabályokat kezel" "Admin portal"
        helpdesk -> greenRide "Felhasználói és utazási adatokat ellenőriz" "Support portal"
        helpdesk -> ticketingSystem "Hibajegyet hoz létre és frissít" "HTTPS"

        greenRide -> iot "Parancsokat küld és telemetria adatokat fogad" "MQTT / HTTPS"
        greenRide -> maps "Térképes és helyadatokat kér le" "HTTPS"
        greenRide -> paymentGateway "Fizetési tranzakciókat indít" "HTTPS"
        greenRide -> identityProvider "Külső bejelentkezést használ" "OIDC / OAuth2"
        greenRide -> notificationProvider "Értesítéseket küld" "HTTPS"
        greenRide -> ticketingSystem "Jegyadatokat szinkronizál" "HTTPS"
    }

    views {
        systemContext greenRide "SystemContext" {
            include *
            autoLayout lr
        }

        styles {
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
        }
    }
}
