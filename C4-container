workspace "GreenRide" "Városi mikromobilitási platform Container szint" {

    model {
        user = person "Utas / Felhasználó" "Járműveket keres és utazik."
        staff = person "Operatív személyzet" "Flottaüzemeltetők, adminok és helpdesk munkatársak."

        iot = softwareSystem "IoT eszközök" "A járművek fedélzeti eszközei." "External"
        maps = softwareSystem "Térkép szolgáltató" "Térképes helymeghatározás és megjelenítés." "External"
        paymentGateway = softwareSystem "Fizetési szolgáltató" "Online fizetések feldolgozása." "External"
        identityProvider = softwareSystem "Külső azonosító szolgáltató" "Google vagy Apple alapú bejelentkezés." "External"
        notificationProvider = softwareSystem "Push és email szolgáltató" "Értesítések kiküldése." "External"
        ticketingSystem = softwareSystem "Jegykezelő rendszer" "Ügyfélszolgálati hibajegyek kezelése." "External"

        greenRide = softwareSystem "GreenRide Platform" {
            mobileApp = container "Mobile App" "Járműkeresés, foglalás és utazásindítás." "Flutter"
            adminPortal = container "Admin and Support Portal" "Flotta, ügyfél és támogatási feladatok kezelése." "React"

            apiGateway = container "API Gateway" "Kérések fogadása, hitelesítés és útválasztás." "Spring Cloud Gateway"

            identityService = container "Identity Service" "Belső felhasználói azonosítás és jogosultságkezelés." "Spring Boot"
            userService = container "User and Subscription Service" "Profilok, bérletek és kedvezmények kezelése." "Spring Boot"
            vehicleService = container "Vehicle Service" "Járművek állapota, helyzete és keresése." "Spring Boot"
            rideService = container "Ride Service" "Utazás indítása, követése és lezárása." "Spring Boot"
            fleetService = container "Fleet Management Service" "Karbantartás és flottaüzemeltetés támogatása." "Spring Boot"
            paymentService = container "Payment Service" "Díjszámítás és fizetési folyamatok kezelése." "Spring Boot"
            notificationService = container "Notification Service" "Push és email értesítések küldése." "Spring Boot"
            supportService = container "Support Service" "Panaszok és ügyfélszolgálati folyamatok kezelése." "Spring Boot"

            messageBus = container "Message Bus" "Aszinkron események továbbítása a szolgáltatások között." "Kafka"
            vehicleCache = container "Vehicle Cache" "Gyakran lekért járműállapotok gyors elérése." "Redis" "Database"

            userDb = container "User DB" "Felhasználói és előfizetési adatok." "PostgreSQL" "Database"
            vehicleDb = container "Vehicle DB" "Járműállapotok és telemetria metaadatok." "PostgreSQL" "Database"
            rideDb = container "Ride DB" "Utazási adatok és események." "PostgreSQL" "Database"
            paymentDb = container "Payment DB" "Fizetési és elszámolási adatok." "PostgreSQL" "Database"
        }

        user -> mobileApp "Használja"
        staff -> adminPortal "Használja"

        mobileApp -> apiGateway "API hívások" "HTTPS"
        adminPortal -> apiGateway "API hívások" "HTTPS"

        apiGateway -> identityService "Bejelentkezés és token ellenőrzés"
        apiGateway -> userService "Profil és előfizetés műveletek"
        apiGateway -> vehicleService "Járműkeresés és állapotlekérdezés"
        apiGateway -> rideService "Utazás indítása és lezárása"
        apiGateway -> fleetService "Flotta műveletek"
        apiGateway -> supportService "Támogatási műveletek"

        identityService -> identityProvider "Külső azonosítás" "OIDC"
        vehicleService -> maps "Térképes adatok" "HTTPS"
        vehicleService -> iot "Telemetria és vezérlés" "MQTT / HTTPS"
        paymentService -> paymentGateway "Fizetés indítása" "HTTPS"
        notificationService -> notificationProvider "Értesítés küldése" "HTTPS"
        supportService -> ticketingSystem "Jegyek kezelése" "HTTPS"

        rideService -> vehicleService "Jármű állapot ellenőrzése"
        rideService -> paymentService "Utazás lezárás utáni díjszámítás"
        rideService -> notificationService "Utazási értesítések"
        rideService -> messageBus "Utazási események publikálása"
        paymentService -> messageBus "Fizetési események publikálása"
        fleetService -> messageBus "Flottaesemények publikálása"
        notificationService -> messageBus "Események feldolgozása"

        vehicleService -> vehicleCache "Olvas és frissít"
        userService -> userDb "Olvas és ír"
        vehicleService -> vehicleDb "Olvas és ír"
        rideService -> rideDb "Olvas és ír"
        paymentService -> paymentDb "Olvas és ír"
    }

    views {
        container greenRide "Containers" {
            include *
            autoLayout lr
        }

        styles {
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Database" {
                shape Cylinder
                background #85bbf0
                color #000000
            }
            element "External" {
                background #999999
                color #ffffff
            }
        }
    }
}
